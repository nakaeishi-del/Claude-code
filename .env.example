# ── データベース（Neon PostgreSQL） ──────────────────────────────
# Neon (https://neon.tech) で作成したDBのURLを貼り付ける
# Vercel統合を使う場合はNeonが自動で設定してくれる
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ── 認証 ─────────────────────────────────────────────────────────
# ランダムな長い文字列を設定（例: openssl rand -base64 32）
JWT_SECRET=change-me-to-a-long-random-string

# ── Google Calendar OAuth ─────────────────────────────────────────
# Google Cloud Console (https://console.cloud.google.com) で取得
# OAuth 2.0 クライアントID を作成し、リダイレクトURIを設定する
# リダイレクトURI: https://あなたのドメイン/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── アプリURL ────────────────────────────────────────────────────
# Vercelデプロイ後のURLに変更する
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/auth/google/callback
