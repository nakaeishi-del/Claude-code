# ── Claude AI (Anthropic) ─────────────────────────────────────────
# https://console.anthropic.com でAPIキーを取得する
# AIで文章を整える機能に使用（なくても動作可能）
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── データベース（Neon PostgreSQL）★シェア機能に必要 ─────────────
# Neon (https://neon.tech) で作成したDBのURLを貼り付ける
# Vercel統合を使う場合はNeonが自動で設定してくれる
# ※ DBなしでも日記をローカル保存する機能は動作します
POSTGRES_PRISMA_URL=postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/dbname?sslmode=require

# ── アプリURL ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
